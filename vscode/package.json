{
  "name": "claude-skills",
  "displayName": "Claude Skills",
  "description": "Browse and install Claude Code skills directly from VS Code",
  "version": "0.1.0",
  "publisher": "surajhk",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["claude", "claude code", "skills", "AI"],
  "repository": {
    "type": "git",
    "url": "https://github.com/surajhk/claude-skills"
  },
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-skills.install",
        "title": "Install Skill",
        "category": "Claude Skills"
      },
      {
        "command": "claude-skills.uninstall",
        "title": "Uninstall Skill",
        "category": "Claude Skills"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
